# Local development: copy to `.env.local` and export before running.
# Production with Docker/Jenkins: put the real values in `/root/turnstile-auth-provider-data/runtime.env`.

# Safe default for local development.
DB_TYPE=sqlite
DB_PATH=results.db

# Production PostgreSQL example.
# DB_TYPE=pgsql
# DATABASE_URL=postgresql://username:password@127.0.0.1:5432/turnstile_auth_provider
# Or use split fields instead of DATABASE_URL:
# PGSQL_HOST=127.0.0.1
# PGSQL_PORT=5432
# PGSQL_USER=postgres
# PGSQL_PASSWORD=replace_me
# PGSQL_DATABASE=turnstile_auth_provider

# Optional app settings
# SESSION_SECRET=replace_me
# TURNSTILE_BROWSER_TYPE=chrome
# TURNSTILE_THREADS=1
# TURNSTILE_HOST=0.0.0.0
# TURNSTILE_PORT=5072
